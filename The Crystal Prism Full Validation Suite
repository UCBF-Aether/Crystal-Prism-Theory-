            root = [0]*8
            root[i] = si
            root[j] = sj
            roots.append(root)
    for signs in product([-1,1], repeat=8):
        if sum(1 for s in signs if s == -1) % 2 == 0:
            roots.append([s/2.0 for s in signs])
    return np.array(roots)

