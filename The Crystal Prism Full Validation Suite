def compute_fcc_sums(max_range=10, n_neighbors=286):
    distances = []
    for x in range(-max_range, max_range+1):
        for y in range(-max_range, max_range+1):
            for z in range(-max_range, max_range+1):
                if (x + y + z) % 2 == 0 and not (x == 0 and y == 0 and z == 0):
                    r = math.sqrt(x*x + y*y + z*z)
                    distances.append(r)
    distances.sort()
    r_neighbors = distances[:n_neighbors]
    S2 = sum(1.0/(r*r) for r in r_neighbors)
    S4 = sum(1.0/(r*r*r*r) for r in r_neighbors)
    return S2, S4

