def main():
    print("\n" + "=" * 80)
    print("  CRYSTAL PRISM v45 — FULL SPARC CATALOG VALIDATION")
    print("=" * 80)
    print(f"  a0_SI = {a0_SI:.4e} m/s²")
    print(f"  Sigma_char = {Sigma_char} M☉/pc²")
    print(f"  ML_DISK = {ML_DISK}, ML_BULGE = {ML_BULGE}")
    print("=" * 80)
    
    # Load data
    print("\n[1] Loading SPARC from Zenodo...")
    galaxies = load_all_sparc()
    
    # Fit all galaxies
    print("\n[2] Fitting all galaxies...")
    results = []
    
    for i, (name, gal) in enumerate(galaxies.items()):
        inc = SPARC_MASTER.get(name, {}).get('inc', 60.0)
        T = SPARC_MASTER.get(name, {}).get('T', -1)
        
        # Fit galaxy
        def objective(x):
            alpha, r_scale = x[0], x[1]
            if alpha < 0.0001 or r_scale < 0.01:
                return 1e15
            V_pred = compute_v7(gal['R_kpc'], gal['V_disk'], gal['V_bul'], gal['V_gas_raw'],
                                ML_DISK, ML_BULGE, inc, alpha, r_scale)[0]
            mask = (gal['V_obs'] > 1.0) & (gal['V_err'] > 0)
            if np.sum(mask) < 3:
                return 1e10
            errs = np.sqrt(gal['V_err'][mask]**2 + (0.05 * gal['V_obs'][mask])**2)
            return np.sum(((V_pred[mask] - gal['V_obs'][mask])**2) / errs**2)
        
        best_chi2, best_x = 1e20, [1.0, 5.0]
        for a0, r0 in [(1, 5), (0.5, 2), (2, 15), (0.2, 0.5), (3, 50)]:
            res = minimize(objective, [a0, r0], method='L-BFGS-B',
                           bounds=[(0.0001, 10000.0), (0.01, 50000.0)])
            if res.fun < best_chi2:
                best_chi2, best_x = res.fun, res.x
        
        alpha_fit, r_scale_fit = best_x
        
        # Compute metrics
        out = compute_v7(gal['R_kpc'], gal['V_disk'], gal['V_bul'], gal['V_gas_raw'],
                         ML_DISK, ML_BULGE, inc, 1.0, 5.0)
        V_pred_u, V_bar, V_flat, a0_eff, r_transition, M_bar, V_gas, V_disk, V_bul = out
        r_transition = V_flat**2 / a0_eff
        
        mask = gal['V_obs'] > 1.0
        N_used = np.sum(mask)
        
        if N_used >= 3:
            V_univ = np.sqrt(V_bar[mask]**2 + (V_flat * (1 - np.exp(-gal['R_kpc'][mask] / r_transition)))**2)
            acc_univ = 100 - np.mean(np.abs(100 * (V_univ - gal['V_obs'][mask]) / gal['V_obs'][mask]))
            res_u = V_univ - gal['V_obs'][mask]
            rms_u = np.sqrt(np.mean(res_u**2))
            errs = np.sqrt(gal['V_err'][mask]**2 + (0.05 * gal['V_obs'][mask])**2)
            chi2_u = np.sum((res_u / errs)**2)
            redchi2_u = chi2_u / max(N_used, 1)
            
            V_fit = np.sqrt(V_bar[mask]**2 + (alpha_fit * V_flat * (1 - np.exp(-gal['R_kpc'][mask] / r_scale_fit)))**2)
            acc_fit = 100 - np.mean(np.abs(100 * (V_fit - gal['V_obs'][mask]) / gal['V_obs'][mask]))
            res_f = V_fit - gal['V_obs'][mask]
            rms_f = np.sqrt(np.mean(res_f**2))
            chi2_f = np.sum((res_f / errs)**2)
            redchi2_f = chi2_f / max(N_used - 2, 1)
        else:
            acc_univ = acc_fit = rms_u = rms_f = np.nan
            redchi2_u = redchi2_f = np.nan
        
        results.append({
            'name': name,
            'T': T,
            'inc': inc,
            'alpha': alpha_fit,
            'r_scale': r_scale_fit,
            'r_transition': r_transition,
            'V_flat': V_flat,
            'a0_eff': a0_eff,
            'M_bar': M_bar,
            'R_max': np.max(gal['R_kpc']),
            'n_pts': len(gal['R_kpc']),
            'acc_univ': acc_univ,
            'acc_fit': acc_fit,
            'rms_u': rms_u,
            'rms_f': rms_f,
            'redchi2_u': redchi2_u,
            'redchi2_f': redchi2_f,
        })
        
        if (i + 1) % 25 == 0:
            print(f"      {i + 1} galaxies...")
    
    # ================================================================
    # SUMMARY
    # ================================================================
    
    print("\n" + "=" * 80)
    print("  RESULTS")
    print("=" * 80)
    
    # Universal model (alpha=1.0 fixed)
    acc_u = [d['acc_univ'] for d in results if not np.isnan(d['acc_univ'])]
    rms_u = [d['rms_u'] for d in results if not np.isnan(d['rms_u'])]
    chi_u = [d['redchi2_u'] for d in results if not np.isnan(d['redchi2_u'])]
    
    print(f"\n  UNIVERSAL MODEL (alpha=1.0 fixed, 1 free parameter):")
    print(f"    Galaxies fitted: {len(acc_u)}/175")
    print(f"    Mean accuracy: {np.mean(acc_u):.1f}%")
    print(f"    Median accuracy: {np.median(acc_u):.1f}%")
    print(f"    Mean RMS: {np.mean(rms_u):.1f} km/s")
    print(f"    Median RMS: {np.median(rms_u):.1f} km/s")
    print(f"    Mean χ²ᵣ: {np.mean(chi_u):.2f}")
    print(f"    Median χ²ᵣ: {np.median(chi_u):.2f}")
    
    # Fitted model (alpha free)
    acc_f = [d['acc_fit'] for d in results if not np.isnan(d['acc_fit'])]
    rms_f = [d['rms_f'] for d in results if not np.isnan(d['rms_f'])]
    chi_f = [d['redchi2_f'] for d in results if not np.isnan(d['redchi2_f'])]
    alphas = [d['alpha'] for d in results]
    
    print(f"\n  FITTED MODEL (alpha, r_scale free, 2 free parameters):")
    print(f"    Galaxies fitted: {len(acc_f)}/175")
    print(f"    Mean accuracy: {np.mean(acc_f):.1f}%")
    print(f"    Median accuracy: {np.median(acc_f):.1f}%")
    print(f"    Mean RMS: {np.mean(rms_f):.1f} km/s")
    print(f"    Median RMS: {np.median(rms_f):.1f} km/s")
    print(f"    Mean χ²ᵣ: {np.mean(chi_f):.2f}")
    print(f"    Median χ²ᵣ: {np.median(chi_f):.2f}")
    print(f"    alpha median: {np.median(alphas):.3f}")
    print(f"    alpha in [0.5, 2.0]: {sum(1 for a in alphas if 0.5 < a < 2.0)}/175")
    
    print("\n" + "=" * 80)
    print("  FINAL SUMMARY")
    print("=" * 80)
    print("\n  Equation:")
    print("    v²(r) = G·M_bar(r)/r + a₀·r·(1 - e^{-r/r_scale})")
    print("\n  Key Results:")
    print(f"    Universal model: {np.mean(acc_u):.1f}% accuracy (0 free params)")
    print(f"    Fitted model: {np.mean(acc_f):.1f}% accuracy (2 free params)")
    print(f"    α naturally at {np.median(alphas):.3f}")
    print("    No dark matter parameters used")
    print("=" * 80)

