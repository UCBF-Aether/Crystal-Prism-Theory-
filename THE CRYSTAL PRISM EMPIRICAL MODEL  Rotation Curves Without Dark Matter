# ============================================================================
# DATA LOADER
# ============================================================================

ZENODO_URL = "https://zenodo.org/records/16284118/files/Rotmod_LTG.zip"

def load_all_sparc(sparc_dir="sparc_data"):
    os.makedirs(sparc_dir, exist_ok=True)
    zip_path = os.path.join(sparc_dir, "Rotmod_LTG.zip")
    if not os.path.exists(zip_path):
        print("Downloading SPARC from Zenodo...")
        r = requests.get(ZENODO_URL, timeout=60)
        r.raise_for_status()
        with open(zip_path, 'wb') as f:
            f.write(r.content)
    if not glob.glob(f"{sparc_dir}/*_rotmod.dat"):
        print("Extracting...")
        with zipfile.ZipFile(zip_path, 'r') as z:
            z.extractall(sparc_dir)
    galaxies = {}
    for fp in sorted(glob.glob(f"{sparc_dir}/*_rotmod.dat")):
        name = os.path.basename(fp).replace('_rotmod.dat', '')
        data = []
        with open(fp) as f:
            for line in f:
                s = line.strip()
                if not s or s.startswith('#'):
                    continue
                p = s.split()
                if len(p) >= 6:
                    try:
                        data.append([float(x) for x in p[:8]])
                    except:
                        continue
        if len(data) < 3:
            continue
        d = np.array(data)
        R, Vo, Ve = d[:,0], d[:,1], d[:,2]
        Vg, Vd, Vb = np.abs(d[:,3]), d[:,4], d[:,5] if d.shape[1] > 5 else np.zeros_like(R)
        m = (Vo > 0) & (Ve > 0) & (R > 0)
        if m.sum() < 3:
            continue
        galaxies[name] = {
            'name': name,
            'R_kpc': R[m],
            'V_obs': Vo[m],
            'V_err': Ve[m],
            'V_gas_raw': Vg[m],
            'V_disk': Vd[m],
            'V_bul': Vb[m],
        }
    print(f"Loaded {len(galaxies)} galaxies from SPARC")
    return galaxies

# ============================================================================
# CRYSTAL PRISM ENGINE (v45)
# ============================================================================

def compute_v7(R_kpc, V_disk_raw, V_bul_raw, V_gas_raw, ml_disk, ml_bul, inc, alpha, r_scale):
    R_kpc = np.asarray(R_kpc, dtype=float)
    if len(R_kpc) != len(V_disk_raw):
        R_orig = np.linspace(0.01, max(R_kpc), len(V_disk_raw))
        V_disk_int = interp1d(R_orig, V_disk_raw, kind='linear', fill_value='extrapolate')(R_kpc)
        V_bul_int = interp1d(R_orig, V_bul_raw, kind='linear', fill_value='extrapolate')(R_kpc)
        V_gas_int = interp1d(R_orig, V_gas_raw, kind='linear', fill_value='extrapolate')(R_kpc)
    else:
        V_disk_int, V_bul_int, V_gas_int = V_disk_raw, V_bul_raw, V_gas_raw
    
    V_disk_ml = V_disk_int * np.sqrt(max(ml_disk, 0.01))
    V_bul_ml = V_bul_int * np.sqrt(max(ml_bul, 0.01))
    V_gas = np.abs(V_gas_int)
    V_bar = np.sqrt(V_gas**2 + V_disk_ml**2 + V_bul_ml**2)
    
    R_pc = R_kpc * kpc_to_pc
    eps = 1e-10
    S_g = np.where(R_pc > eps, V_gas**2 / (2 * np.pi * G_PC * R_pc), 0)
    S_d = np.where(R_pc > eps, V_disk_ml**2 / (2 * np.pi * G_PC * R_pc), 0)
    S_b = np.where(R_pc > eps, V_bul_ml**2 / (2 * np.pi * G_PC * R_pc), 0)
    S_bar = S_g + S_d + S_b
    
    Vb2R = V_bar**2 * R_pc
    M_bar = np.max(Vb2R) / G_PC
    
    Vf0 = (a0_SI * G_SI * M_bar * M_sun_kg)**0.25 / 1000.0
    rt0 = np.clip(Vf0**2 / a0_base, min(R_kpc) * 1.01, max(R_kpc) * 0.99)
    St0 = np.interp(rt0, R_kpc, S_bar)
    a0_0 = a0_base * np.sqrt(np.clip(St0 / Sigma_char, 0.01, 100.0))
    Vf1 = (a0_0 * (a0_SI / a0_base) * G_SI * M_bar * M_sun_kg)**0.25 / 1000.0
    
    rt = np.clip(Vf1**2 / a0_base, min(R_kpc) * 1.01, max(R_kpc) * 0.99)
    St = np.interp(rt, R_kpc, S_bar)
    a0_eff = a0_base * np.sqrt(np.clip(St / Sigma_char, 0.01, 100.0))
    V_flat = (a0_eff * (a0_SI / a0_base) * G_SI * M_bar * M_sun_kg)**0.25 / 1000.0
    
    r_transition = V_flat**2 / a0_eff
    V_vortex = alpha * V_flat * (1.0 - np.exp(-R_kpc / r_scale))
    V_pred = np.sqrt(V_bar**2 + V_vortex**2)
    
    return V_pred, V_bar, V_flat, a0_eff, r_transition, M_bar, V_gas, V_disk_ml, V_bul_ml

