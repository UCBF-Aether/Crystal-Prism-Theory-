def arctan_series(x, terms=50):
    """arctan(x) = x - x³/3 + x⁵/5 - x⁷/7 + ..."""
    result = 0.0
    for n in range(terms):
        result += ((-1)**n) * (x**(2*n+1)) / (2*n+1)
    return result

