def evolve(phi0, A0, steps=800, dt=0.001):
    p = phi0.copy()
    g = A0.copy()
    vp = np.zeros_like(p)
    vg = np.zeros_like(g)

    for step in range(steps):
        Fphi, FA = force(p, g)
        vp += 0.5 * dt * Fphi
        vg += 0.5 * dt * FA
        p += dt * vp
        g += dt * vg
        g = (g + np.pi) % (2 * np.pi) - np.pi

        current_flux = np.sum(g[flux_links])
        flux_error = target_flux - current_flux
