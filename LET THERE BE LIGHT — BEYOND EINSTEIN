def total_energy(phi_field, A):
    E_grad = 0.0
    for n, (i, j) in enumerate(bonds):
        Uij = np.exp(1j * A[n])
        diff = phi_field[i] - Uij * phi_field[j]
        E_grad += abs(diff)**2

    rho2 = np.abs(phi_field)**2
    E_hat = np.sum(lambda_higgs * (rho2 - eta_higgs**2)**2)

    E_mag = 0.0
    count = 0
    for i, j in bonds:
        for k in neighbors[i]:
            if k != j:
                e1 = get_edge(i, j)
                e2 = get_edge(j, k)
                e3 = get_edge(i, k)
                if e1 is None or e2 is None or e3 is None:
                    continue
                flux = A[e1] + A[e2] - A[e3]
                flux = (flux + np.pi) % (2 * np.pi) - np.pi
                E_mag += (1 - np.cos(flux))
                count += 1
    if count > 0:
        E_mag = gauge_strength * E_mag / count

    total_flux = np.sum(A[flux_links])
    E_flux = flux_penalty * (total_flux - target_flux)**2
    E_pin = core_pin * abs(phi_field[core])**2

    E_local = 0.0
    for i in range(N):
        r = np.linalg.norm(xy[i] - center)
        if r < localization_radius:
            E_local += localization_strength * r**2 * abs(phi_field[i])**2

    return E_grad + E_hat + E_mag + E_flux + E_pin + E_local

def force(phi_field, A):
    Fphi = np.zeros_like(phi_field)
    FA = np.zeros_like(A)

    rho2 = np.abs(phi_field)**2
    Fphi += -4 * lambda_higgs * (rho2 - eta_higgs**2) * phi_field
    Fphi[core] += -2 * core_pin * phi_field[core]

    for i in range(N):
        r = np.linalg.norm(xy[i] - center)
        if r < localization_radius:
            Fphi[i] -= 2 * localization_strength * r**2 * phi_field[i]

    for n, (i, j) in enumerate(bonds):
        Uij = np.exp(1j * A[n])
        diff = phi_field[i] - Uij * phi_field[j]
        Fphi[i] -= 2 * diff
        Fphi[j] += 2 * np.conj(Uij) * diff
        FA[n] += 2 * np.imag(np.conj(phi_field[i]) * Uij * phi_field[j])

    FA -= gauge_strength * np.sin(A)
    total_flux = np.sum(A[flux_links])
    for n in flux_links:
        FA[n] -= 2 * flux_penalty * (total_flux - target_flux)

    return Fphi, FA

