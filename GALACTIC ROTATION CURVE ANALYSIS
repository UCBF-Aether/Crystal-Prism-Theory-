        inc=SPARC_MASTER.get(nm,{}).get('inc',60); T=SPARC_MASTER.get(nm,{}).get('T',-1)
        a,r=fit_galaxy(gal)
        _,Vb,Vf,a0,rt,Mb,Vg,Vd,Vb_ml=cp_predict(gal['R_kpc'],gal['V_disk'],gal['V_bul'],
                                                  gal['V_gas_raw'],ML_DISK,ML_BULGE,1,5)
        rt=Vf**2/a0
        Vgu=np.interp(rt,gal['R_kpc'],Vg); Vbu=np.interp(rt,gal['R_kpc'],Vb)
        fg=Vgu**2/max(Vbu**2,0.01)
        m=gal['V_obs']>1; N=m.sum()
        if N>=3:
            Vu=np.sqrt(Vb[m]**2+(Vf*(1-np.exp(-gal['R_kpc'][m]/rt)))**2)
            au=100-np.mean(np.abs(100*(Vu-gal['V_obs'][m])/gal['V_obs'][m]))
            Vp=np.sqrt(Vb[m]**2+(a*Vf*(1-np.exp(-gal['R_kpc'][m]/r)))**2)
            af=100-np.mean(np.abs(100*(Vp-gal['V_obs'][m])/gal['V_obs'][m]))
            ru=np.sqrt(np.mean((Vu-gal['V_obs'][m])**2))
            rf=np.sqrt(np.mean((Vp-gal['V_obs'][m])**2))
            e=np.sqrt(gal['V_err'][m]**2+(0.05*gal['V_obs'][m])**2)
            cu=np.sum(((Vu-gal['V_obs'][m])/e)**2)/max(N,1)
            cf=np.sum(((Vp-gal['V_obs'][m])/e)**2)/max(N-2,1)
        else: au=af=ru=rf=cu=cf=np.nan
        res.append({'name':nm,'T':T,'n':len(gal['R_kpc']),'Rmax':max(gal['R_kpc']),
                    'Vf':Vf,'a0':a0,'Mb':Mb,'fg':fg,'a':a,'r':r,'rt':rt,
                    'au':au,'af':af,'ru':ru,'rf':rf,'cu':cu,'cf':cf})
