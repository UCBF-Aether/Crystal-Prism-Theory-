                       f"{d['af']:.2f}" if not np.isnan(d['af']) else "",
                       f"{d['ru']:.2f}" if not np.isnan(d['ru']) else "",
                       f"{d['rf']:.2f}" if not np.isnan(d['rf']) else "",
                       f"{d['cu']:.3f}" if not np.isnan(d['cu']) else "",
                       f"{d['cf']:.3f}" if not np.isnan(d['cf']) else ""])
    with open('crystal_prism_clusters.csv','w',newline='') as f:
