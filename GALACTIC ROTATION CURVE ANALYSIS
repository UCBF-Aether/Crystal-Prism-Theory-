def load_sparc(d="sparc_data"):
    os.makedirs(d,exist_ok=True)
    z=os.path.join(d,"Rotmod_LTG.zip")
    if not os.path.exists(z):
        print("Downloading SPARC...")
        r=requests.get(ZENODO,timeout=60); r.raise_for_status()
        with open(z,'wb') as f: f.write(r.content)
    if not glob.glob(f"{d}/*_rotmod.dat"):
        print("Extracting...")
        with zipfile.ZipFile(z,'r') as zf: zf.extractall(d)
    g={}
    for fp in sorted(glob.glob(f"{d}/*_rotmod.dat")):
        nm=os.path.basename(fp).replace('_rotmod.dat','')
        dat=[]
        with open(fp) as f:
            for ln in f:
                s=ln.strip()
                if not s or s.startswith('#'): continue
                p=s.split()
                if len(p)>=6:
                    try: dat.append([float(x) for x in p[:8]])
                    except: continue
        if len(dat)<3: continue
        a=np.array(dat)
        R,Vo,Ve=a[:,0],a[:,1],a[:,2]
        Vg,Vd,Vb=np.abs(a[:,3]),a[:,4],a[:,5] if a.shape[1]>5 else np.zeros_like(R)
        m=(Vo>0)&(Ve>0)&(R>0)
        if m.sum()<3: continue
        g[nm]={'name':nm,'R_kpc':R[m],'V_obs':Vo[m],'V_err':Ve[m],
               'V_gas_raw':Vg[m],'V_disk':Vd[m],'V_bul':Vb[m]}
    print(f"Loaded {len(g)} galaxies")
    return g

