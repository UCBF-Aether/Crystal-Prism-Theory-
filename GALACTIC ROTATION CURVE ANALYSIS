# ================================================================
# PHYSICS ENGINE
# ================================================================
def cp_predict(R,Vd,Vb,Vg,ml_d=ML_DISK,ml_b=ML_BULGE,alpha=1.0,rs=None):
    R=np.asarray(R,dtype=float)
    if len(R)!=len(Vd):
        Ro=np.linspace(0.01,max(R),len(Vd))
        Vdi=interp1d(Ro,Vd,kind='linear',fill_value='extrapolate')(R)
        Vbi=interp1d(Ro,Vb,kind='linear',fill_value='extrapolate')(R)
        Vgi=interp1d(Ro,Vg,kind='linear',fill_value='extrapolate')(R)
    else: Vdi,Vbi,Vgi=Vd,Vb,Vg
    Vdm=Vdi*np.sqrt(max(ml_d,0.01)); Vbm=Vbi*np.sqrt(max(ml_b,0.01))
    Vg=np.abs(Vgi); Vbar=np.sqrt(Vg**2+Vdm**2+Vbm**2)
    Rp=R*C.kpc_to_pc; ep=1e-10
    Sg=np.where(Rp>ep,Vg**2/(2*np.pi*C.G_PC*Rp),0)
    Sd=np.where(Rp>ep,Vdm**2/(2*np.pi*C.G_PC*Rp),0)
    Sb=np.where(Rp>ep,Vbm**2/(2*np.pi*C.G_PC*Rp),0)
    Sbar=Sg+Sd+Sb
    Vb2R=Vbar**2*Rp; Mb=np.max(Vb2R)/C.G_PC
    Vf0=(C.a0_SI*C.G_SI*Mb*C.M_sun_kg)**0.25/1000
    rt0=np.clip(Vf0**2/C.a0_base,min(R)*1.01,max(R)*0.99)
    St0=np.interp(rt0,R,Sbar)
    a0_0=C.a0_base*np.sqrt(np.clip(St0/C.Sigma_char,0.01,100))
    Vf1=(a0_0*(C.a0_SI/C.a0_base)*C.G_SI*Mb*C.M_sun_kg)**0.25/1000
    rt=np.clip(Vf1**2/C.a0_base,min(R)*1.01,max(R)*0.99)
    St=np.interp(rt,R,Sbar)
    a_eff=C.a0_base*np.sqrt(np.clip(St/C.Sigma_char,0.01,100))
    Vflat=(a_eff*(C.a0_SI/C.a0_base)*C.G_SI*Mb*C.M_sun_kg)**0.25/1000
    rt=Vflat**2/a_eff
    if rs is None: rs=rt
    Vv=alpha*Vflat*(1-np.exp(-R/rs))
    return np.sqrt(Vbar**2+Vv**2),Vbar,Vflat,a_eff,rt,Mb,Vg,Vdm,Vbm

def fit_galaxy(gal):
    def obj(x):
        a,r=x[0],x[1]
        if a<0.0001 or r<0.01: return 1e15
        Vp=cp_predict(gal['R_kpc'],gal['V_disk'],gal['V_bul'],gal['V_gas_raw'],
                      ML_DISK,ML_BULGE,a,r)[0]
        m=(gal['V_obs']>1)&(gal['V_err']>0)
        if m.sum()<3: return 1e10
        e=np.sqrt(gal['V_err'][m]**2+(0.05*gal['V_obs'][m])**2)
        return np.sum(((Vp[m]-gal['V_obs'][m])**2)/e**2)
    bc,bx=1e20,[1,5]
    for a0,r0 in [(1,5),(0.5,2),(2,15),(0.2,0.5),(3,50)]:
        res=minimize(obj,[a0,r0],method='L-BFGS-B',bounds=[(0.0001,10000),(0.01,50000)])
        if res.fun<bc: bc,bx=res.fun,res.x
    return bx[0],bx[1]

