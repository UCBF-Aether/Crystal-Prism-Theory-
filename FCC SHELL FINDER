def arctan_series(x, n=50):
    """arctan(x) from series expansion — NO math.atan()"""
    result = 0.0
    for i in range(n):
        term = (x ** (2*i + 1)) / (2*i + 1)
        result += term if i % 2 == 0 else -term
    return result

def derive_pi():
    """Derive π from Machin's formula — NO math.pi"""
    return 4.0 * (4.0 * arctan_series(1.0/5.0) - arctan_series(1.0/239.0))

