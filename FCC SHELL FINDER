def construct_a5_projection():
    """
    Construct the exact A5 projection matrix.
    
    This maps E8 (8D) to 3D via the icosahedral projection:
    P(x) = (x₁ + φx₅, x₂ + φx₆, x₃ + φx₇) / √(2+φ)
    
    The (4,8) coordinates are projected into the 5D perpendicular space.
    """
    norm = 1.0 / math.sqrt(2.0 + phi)
    
    P = np.zeros((3, 8))
    P[0, 0] = norm
    P[0, 4] = phi * norm
    P[1, 1] = norm
    P[1, 5] = phi * norm
    P[2, 2] = norm
    P[2, 6] = phi * norm
    
    return P

