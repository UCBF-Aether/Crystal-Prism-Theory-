    for scale in scales:
        projected = project_roots(roots, P, scale=scale)
        result = find_shells(projected, verbose=False)
        if result['found']:
            found.append((scale, result['radius'], result))
    
    return found

# ============================================================================
# PART 7: ANALYZE SHELL — CONSTRUCT PRIMITIVE BASIS
# ============================================================================

def construct_primitive_basis(vectors):
    """Find the primitive basis from FCC shell vectors"""
    best_det = float('inf')
    best_basis = None
    
    n = len(vectors)
    for i in range(n):
        for j in range(i+1, n):
            for k in range(j+1, n):
                M = np.vstack([vectors[i], vectors[j], vectors[k]])
                if M.shape == (3, 3):
                    det = abs(np.linalg.det(M))
                    if det > 1e-6 and det < best_det:
                        best_det = det
                        best_basis = M
    
    return best_basis, best_det

