def generate_e8():
    """Generate all 240 E8 roots exactly"""
    roots = []
    
    # 112 integer roots: (±1, ±1, 0, 0, 0, 0, 0, 0)
    for i, j in combinations(range(8), 2):
        for s1, s2 in [(-1, -1), (-1, 1), (1, -1), (1, 1)]:
            v = np.zeros(8)
            v[i] = s1
            v[j] = s2
            roots.append(v)
    
    # 128 half-integer roots: (±½, ±½, ..., ±½) with even number of minus signs
    for signs in product([-1, 1], repeat=8):
        if sum(signs) % 4 == 0:  # even number of minus signs
            roots.append(np.array(signs) / 2)
    
    return np.array(roots)

