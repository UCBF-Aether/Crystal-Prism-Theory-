def project_roots(roots, P, scale=1.0):
    """Project E8 roots through A5 with optional scaling"""
    return roots @ P.T * scale

# ============================================================================
# PART 5: FIND SHELLS IN PROJECTED POINTS
# ============================================================================

def find_shells(projected, target_r=2.828427, verbose=True):
    """
    Find shells in the projected points and check for FCC signature.
    
    FCC signature:
    - 12 vectors at radius r = 2√2
    - Angles between vectors: {-1, -0.5, 0, 0.5}
    - 6 opposite pairs
    """
    
    # Find unique points
    unique = []
    for p in projected:
        if not any(np.linalg.norm(p - u) < 1e-8 for u in unique):
            unique.append(p)
    unique = np.array(unique)
    
    if verbose:
        print(f"  Unique points: {len(unique)}")
    
    # Build difference lattice
    diff = []
    for i in range(len(unique)):
        for j in range(i+1, len(unique)):
            d = unique[i] - unique[j]
            if np.linalg.norm(d) > 1e-8:
                diff.append(d)
                diff.append(-d)
    diff = np.array(diff)
    
    if verbose:
        print(f"  Difference vectors: {len(diff)}")
    
    # Group by radius
    norms = np.linalg.norm(diff, axis=1)
    shells = {}
    for i, n in enumerate(norms):
        r = round(n, 6)
        if r not in shells:
            shells[r] = []
        shells[r].append(diff[i])
    
    # Check each shell for FCC signature
    fcc_found = False
    fcc_radius = None
    fcc_vectors = None
    fcc_opposite_pairs = 0
    fcc_angles = None
    
    for r, vecs in sorted(shells.items()):
        if len(vecs) >= 12:
            # Check radius near target
            if abs(r - target_r) > 0.1:
                continue
                
            # Take 12 vectors
            test_vecs = vecs[:12]
            
            # Check angles
            angles = []
            for i in range(len(test_vecs)):
                for j in range(i+1, len(test_vecs)):
                    cos_angle = np.dot(test_vecs[i], test_vecs[j]) / (
                        np.linalg.norm(test_vecs[i]) * np.linalg.norm(test_vecs[j])
                    )
                    angles.append(round(cos_angle, 6))
            
            angle_set = set(angles)
            expected = {-1.0, -0.5, 0.0, 0.5}
            
            # Check opposite pairs
            opp_pairs = 0
            for i, v in enumerate(test_vecs):
                for w in test_vecs[i+1:]:
                    if np.linalg.norm(v + w) < 1e-6:
                        opp_pairs += 1
            
            # Check if this is FCC
            if opp_pairs == 6 and angle_set == expected:
                fcc_found = True
                fcc_radius = r
                fcc_vectors = test_vecs
                fcc_opposite_pairs = opp_pairs
                fcc_angles = angle_set
                break
            
            # Store closest candidate
            if not fcc_found:
                fcc_radius = r
                fcc_vectors = test_vecs
                fcc_opposite_pairs = opp_pairs
                fcc_angles = angle_set
    
    return {
        'found': fcc_found,
        'radius': fcc_radius,
        'vectors': fcc_vectors,
        'opposite_pairs': fcc_opposite_pairs,
        'angles': fcc_angles,
        'shells': shells,
        'num_shells': len(shells),
        'num_unique': len(unique),
        'num_diff': len(diff),
    }

