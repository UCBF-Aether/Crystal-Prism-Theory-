print()
print(f"  C₄₄ = {c44_target:.4e} Pa")
print()

rho = c44_target / (c * c)
print(f"  ρ = C₄₄/c² = {rho:.4e} kg/m³")
print()

print("  C₄₄ SHEAR MODULUS COMPLETE.")
