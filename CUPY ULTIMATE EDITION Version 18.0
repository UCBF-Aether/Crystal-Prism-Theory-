# ----------------------------------------------------------------------------
# 1.1: π — Machin's Formula
# ----------------------------------------------------------------------------

print("=" * 40)
print("1.1: COMPUTING π")
print("-" * 40)
print()
print("FORMULA: π = 4 × (4 × arctan(1/5) − arctan(1/239))")
print()

def compute_pi_detailed(iterations: int = 50):
    """Compute π with every step displayed."""
    
    def arctan_series(x, n):
        result = Decimal(0)
        x_pow = Decimal(x)
        for i in range(n):
            term = x_pow / Decimal(2*i + 1)
            if i % 2 == 1:
                term = -term
            result += term
            x_pow *= Decimal(x) * Decimal(x)
            if i < 10:
                print(f"    i={i:2d}: term = {term:.20f}, partial = {result:.20f}")
            elif i == 10:
                print("    ... (continuing to 50 terms)")
        return result
    
    print("  arctan(1/5) terms:")
    print("  " + "-" * 60)
    x5 = Decimal(1) / Decimal(5)
    arctan_5 = arctan_series(x5, iterations)
    print()
    
    print("  arctan(1/239) terms:")
    print("  " + "-" * 60)
    x239 = Decimal(1) / Decimal(239)
    arctan_239 = arctan_series(x239, iterations)
    print()
    
    pi = Decimal(4) * (Decimal(4) * arctan_5 - arctan_239)
    print(f"  π = {pi:.30f}")
    return pi

pi_val = compute_pi_detailed(50)
print()

