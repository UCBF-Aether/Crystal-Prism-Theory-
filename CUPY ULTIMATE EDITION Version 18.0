R = m_mu_me
sqrt_R = math.sqrt(R)
a_coef = 1.0
b_coef = -4.0 * (1.0 + sqrt_R)
c_coef = 3.0 * (1.0 + R) - 2.0 * (1.0 + sqrt_R) ** 2
disc = b_coef*b_coef - 4*a_coef*c_coef
r_val = (-b_coef + math.sqrt(disc)) / (2.0 * a_coef)
m_tau_me = r_val * r_val

print(f"  R = {R:.5f}")
print(f"  √R = {sqrt_R:.5f}")
print()
print(f"  a = {a_coef:.1f}")
print(f"  b = {b_coef:.5f}")
