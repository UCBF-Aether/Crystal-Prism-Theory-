def project_root(root, phi, A):
    x = [float(r) for r in root]
    return (
        A * (x[0] + phi * x[4]),
        A * (x[1] + phi * x[5]),
        A * (x[2] + phi * x[6])
    )

# Use GPU if available
if GPU_AVAILABLE:
    print("  Using GPU acceleration for projections...")
    # Convert roots to GPU array
    roots_array = cp.array(all_roots, dtype=cp.float64)
    # Project using GPU
    projected_gpu = cp.zeros((len(all_roots), 3), dtype=cp.float64)
    # Vectorized GPU projection
    projected_gpu[:, 0] = A * (roots_array[:, 0] + phi_float * roots_array[:, 4])
    projected_gpu[:, 1] = A * (roots_array[:, 1] + phi_float * roots_array[:, 5])
    projected_gpu[:, 2] = A * (roots_array[:, 2] + phi_float * roots_array[:, 6])
    projected = projected_gpu.get()
else:
    print("  Using CPU for projections...")
    projected = [project_root(r, phi_float, A) for r in all_roots]

# Display all 240 projections
for idx, p in enumerate(projected):
    print(f"  Root {idx+1:3d}: ({p[0]:8.6f}, {p[1]:8.6f}, {p[2]:8.6f})")

