def compute_phi_detailed():
    print("  Computing √5 using Newton's method:")
    sqrt5 = Decimal(2)
    for i in range(10):
        sqrt5_new = (sqrt5 + Decimal(5)/sqrt5) / Decimal(2)
        print(f"    Iteration {i+1:2d}: {sqrt5_new:.30f}")
        if abs(sqrt5_new - sqrt5) < Decimal('1e-50'):
            sqrt5 = sqrt5_new
            break
        sqrt5 = sqrt5_new
    print()
    
    phi = (Decimal(1) + sqrt5) / Decimal(2)
    print(f"  φ = {phi:.30f}")
    print(f"  φ² = {phi*phi:.30f}")
    print(f"  1/φ = {Decimal(1)/phi:.30f}")
    return phi

phi_val = compute_phi_detailed()
print()

