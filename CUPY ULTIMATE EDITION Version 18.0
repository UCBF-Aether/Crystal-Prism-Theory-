print("=" * 40)
print("1.3: COMPUTING e (EULER'S NUMBER)")
print("-" * 40)
print()
print("FORMULA: e = Σ 1/n! (n = 0 to ∞)")
print()

def compute_e_detailed(iterations: int = 50):
    result = Decimal(1)
    factorial = Decimal(1)
    print("  n=0: 1/0! = 1.000000000000, partial = 1.000000000000")
    for n in range(1, iterations):
        factorial *= Decimal(n)
        term = Decimal(1) / factorial
        result += term
        if n <= 15:
            print(f"  n={n:2d}: 1/{n}! = {term:.12f}, partial = {result:.20f}")
        elif n == 16:
            print("  ... (continuing to 50 terms)")
    print(f"\n  e = {result:.30f}")
    return result

e_val = compute_e_detailed(50)
print()

# ----------------------------------------------------------------------------
# 1.4: γ — Euler-Mascheroni
# ----------------------------------------------------------------------------

print("=" * 40)
print("1.4: COMPUTING γ (EULER-MASCHERONI CONSTANT)")
print("-" * 40)
print()
print("FORMULA: γ = lim(Σ1/k - ln(n))")
print()
print("  Computing with n = 100,000 terms...")
print()

def compute_gamma_detailed(n: int = 100000):
    harmonic = Decimal(0)
    progress_step = n // 10
    
    for k in range(1, n + 1):
        harmonic += Decimal(1) / Decimal(k)
        if k % progress_step == 0:
            print(f"    Progress: {k//progress_step*10:3d}% complete, H_{k} = {harmonic:.20f}")
    
    print()
    ln_n = Decimal(n).ln()
    print(f"  H_{n} = {harmonic:.30f}")
    print(f"  ln({n}) = {ln_n:.30f}")
    print()
    
    gamma = harmonic - ln_n
    print(f"  γ = {gamma:.30f}")
    return gamma

gamma_val = compute_gamma_detailed(100000)
print()

