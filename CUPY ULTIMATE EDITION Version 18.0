def generate_type1_roots_detailed():
    roots = []
    idx = 0
    for i, j in itertools.combinations(range(8), 2):
        for s1 in [-1, 1]:
            for s2 in [-1, 1]:
                vec = [0] * 8
                vec[i] = s1
                vec[j] = s2
                roots.append(tuple(vec))
                idx += 1
                print(f"  Root {idx:3d}: [{vec[0]:2d}, {vec[1]:2d}, {vec[2]:2d}, {vec[3]:2d}, {vec[4]:2d}, {vec[5]:2d}, {vec[6]:2d}, {vec[7]:2d}]")
    return roots

