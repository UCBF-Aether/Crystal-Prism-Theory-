def generate_type2_roots_detailed():
    roots = []
    idx = 0
    for bits in range(256):
        if bin(bits).count('1') % 2 == 0:
            vec = [0.5 if (bits >> i) & 1 == 0 else -0.5 for i in range(8)]
            roots.append(tuple(vec))
            idx += 1
            vec_str = [f"{x:+4.1f}" for x in vec]
            print(f"  Root {idx:3d}: [{vec_str[0]}, {vec_str[1]}, {vec_str[2]}, {vec_str[3]}, {vec_str[4]}, {vec_str[5]}, {vec_str[6]}, {vec_str[7]}]")
    return roots

