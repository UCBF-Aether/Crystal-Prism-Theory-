print()
print(f"  r = {r_val:.5f}")
print(f"  m_τ/m_e = r² = {m_tau_me:.5f}")
print()

m_tau_me_obs = 3477.44
err_tau = abs(m_tau_me - m_tau_me_obs) / m_tau_me_obs * 100
print(f"  Observed: {m_tau_me_obs:.2f}")
print(f"  Error: {err_tau:.4f}%")
