print("FORMULA: ζ(s) = Σ 1/n^s")
print()

def compute_zeta_detailed(s: int, n: int = 100000):
    result = Decimal(0)
    progress_step = n // 10
    print(f"  Computing ζ({s}) with {n:,} terms...")
    
    for k in range(1, n + 1):
        k_dec = Decimal(k)
        result += Decimal(1) / (k_dec ** s)
        if k % progress_step == 0:
            print(f"    {k//progress_step*10:3d}% complete, partial = {result:.20f}")
    
    print(f"  ζ({s}) = {result:.30f}")
    return result

