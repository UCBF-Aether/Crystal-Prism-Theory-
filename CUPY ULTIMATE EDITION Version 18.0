c44_target = 4.6205e34  # Pa
V_cell = a**3 / 4.0
Vpp = c44_target * V_cell / S

print(f"  a = {a:.6e} m")
print(f"  V_cell = a³/4 = {V_cell:.6e} m³")
print(f"  S = {S:.6f}")
print()
