# π — Machin's formula
def arctan(x, n):
    result = 0.0
    for i in range(n):
        term = ((-1)**i) * (x**(2*i+1)) / (2*i+1)
        result += term
        if i < 5:
            print(f"  arctan({x:.3f}) term {i}: {term:.12f}")
    return result

